<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart - Quick 2 Pay</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white">
    <div class="container mx-auto max-w-md p-4">
        <h1 class="text-2xl font-bold text-yellow-400 mb-4">Your Cart</h1>
        <div id="cartItems" class="space-y-2 mb-4"></div>
        <div class="border-t border-gray-700 pt-2 flex justify-between font-bold text-lg">
            <span>Total:</span>
            <span id="totalAmount">$0.00</span>
        </div>
        <div class="flex gap-2 mt-4">
            <button id="addMoreBtn" class="flex-1 bg-gray-700 text-white py-3 rounded-lg font-semibold">+ Add More Items</button>
            <button id="checkoutBtn" class="flex-1 bg-yellow-500 text-black py-3 rounded-lg font-bold">Proceed to Pay</button>
        </div>
        <a href="/customer/dashboard" class="block text-center text-gray-400 mt-4">← Back to Dashboard</a>
    </div>
    <script>
        let cart = JSON.parse(sessionStorage.getItem('checkoutCart') || '[]');
        let merchantId = sessionStorage.getItem('checkoutMerchantId');

        function renderCart() {
            const container = document.getElementById('cartItems');
            if (cart.length === 0) { container.innerHTML = '<div class="text-gray-500">Cart is empty</div>'; document.getElementById('totalAmount').innerText = '$0.00'; return; }
            container.innerHTML = cart.map((item, idx) => `
                <div class="bg-gray-800 p-3 rounded flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        ${item.image_url ? `<img src="${item.image_url}" class="w-12 h-12 object-cover rounded">` : '<div class="w-12 h-12 bg-gray-700 rounded"></div>'}
                        <div>
                            <div class="font-semibold">${item.name}</div>
                            <div class="text-sm">$${(item.price/100).toFixed(2)} each</div>
                        </div>
                    </div>
                    <div class="flex items-center space-x-2">
                        <button class="qty-dec bg-gray-700 px-2 py-1 rounded" data-index="${idx}">-</button>
                        <span class="w-8 text-center">${item.quantity}</span>
                        <button class="qty-inc bg-gray-700 px-2 py-1 rounded" data-index="${idx}">+</button>
                        <button class="remove-item bg-red-700 px-2 py-1 rounded" data-index="${idx}">✕</button>
                    </div>
                </div>
            `).join('');
            attachEvents();
            updateTotal();
        }

        function attachEvents() {
            document.querySelectorAll('.qty-dec').forEach(btn => btn.addEventListener('click', (e) => { let idx = parseInt(btn.dataset.index); if (cart[idx].quantity > 1) cart[idx].quantity--; else cart.splice(idx,1); renderCart(); updateTotal(); }));
            document.querySelectorAll('.qty-inc').forEach(btn => btn.addEventListener('click', (e) => { let idx = parseInt(btn.dataset.index); cart[idx].quantity++; renderCart(); updateTotal(); }));
            document.querySelectorAll('.remove-item').forEach(btn => btn.addEventListener('click', (e) => { let idx = parseInt(btn.dataset.index); cart.splice(idx,1); renderCart(); updateTotal(); }));
        }

        function updateTotal() { 
            let total = cart.reduce((sum,i) => sum + (i.price * i.quantity), 0); 
            document.getElementById('totalAmount').innerText = `$${(total/100).toFixed(2)}`; 
            sessionStorage.setItem('checkoutCart', JSON.stringify(cart));
            sessionStorage.setItem('checkoutMerchantId', merchantId);
        }

        document.getElementById('addMoreBtn').addEventListener('click', () => {
            window.location.href = '/customer/scan-more';
        });

        document.getElementById('checkoutBtn').addEventListener('click', async () => {
            if (cart.length === 0) return alert('Cart empty');
            const totalCents = cart.reduce((s,i) => s + (i.price * i.quantity), 0);
            const itemsForBackend = cart.map(i => ({ barcode: i.barcode, quantity: i.quantity, price: i.price }));
            const response = await fetch('/customer/api/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ merchantId, items: itemsForBackend, totalCents })
            });
            const data = await response.json();
            if (data.success) {
                sessionStorage.removeItem('checkoutCart');
                sessionStorage.removeItem('checkoutMerchantId');
                window.location.href = `/customer/receipt/${data.transactionId}`;
            } else {
                alert('Payment failed: ' + data.message);
            }
        });

        renderCart();
    </script>
</body>
</html>